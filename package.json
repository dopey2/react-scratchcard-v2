    "prepare": "tsdown"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.7.0",
    "eslint-plugin-react": "^7.17.0",
    "prettier": "^2.0.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsdown": "^0.21.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ]
}
