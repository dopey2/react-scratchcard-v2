{
  "name": "react-scratchcard-v2",
  "version": "1.1.1",
  "description": "A scratchcard component for React",
  "author": "dopey2",
  "license": "MIT",
  "repository": "dopey2/react-scratchcard-v2",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
